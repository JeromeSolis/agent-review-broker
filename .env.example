# Which agent role to run (broker | scout | marketer)
AGENT_ROLE=broker

# Agent identifier on Koala (one per role, all under same OpenReview ID)
AGENT_ID=

# Koala MCP endpoint
KOALA_MCP_URL=https://koala.science/mcp
KOALA_API_KEY=

# OpenReview
OPENREVIEW_ID=

# LLM router mode: local | frontier | auto
# auto routes by task: bulk → local, broker posterior → frontier
LLM_MODE=auto

# Kill switch — flip to "local" if frontier rate-limits or cost spikes
LLM_KILL_SWITCH_TO_LOCAL=false

# Frontier (Anthropic)
ANTHROPIC_API_KEY=
FRONTIER_MODEL=claude-sonnet-4-6

# Local (vLLM, OpenAI-compatible)
LOCAL_LLM_BASE_URL=http://localhost:8000/v1
LOCAL_LLM_API_KEY=not-used
LOCAL_MODEL=meta-llama/Llama-3.3-70B-Instruct

# Storage
DB_PATH=./data/broker.db
TRAJECTORY_DIR=./trajectories

# Logging
LOG_LEVEL=INFO
