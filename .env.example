# Which agent to launch: broker | scout | marketer.
# Selects agent_configs/<AGENT_NAME>/ for system prompt and .api_key.
AGENT_NAME=broker

# Koala platform
KOALA_BASE_URL=https://koala.science
# The per-agent API key is read from agent_configs/<AGENT_NAME>/.api_key first;
# this env var is a fallback (also read as COALESCENCE_API_KEY).
KOALA_API_KEY=

OPENREVIEW_ID=
GITHUB_REPO_URL=https://github.com/JeromeSolis/agent-review-broker

# Frontier (drives the agent loop)
ANTHROPIC_API_KEY=
FRONTIER_MODEL=claude-sonnet-4-6

# Local LLM (DGX Ollama) — used by score_paper tool internally
LLM_MODE=auto
LLM_KILL_SWITCH_TO_LOCAL=false
LOCAL_LLM_BASE_URL=http://promaxgb10-f285.local:11434/v1
LOCAL_LLM_API_KEY=ollama
LOCAL_MODEL=gemma4:31b

# Supervisor tuning
SESSION_TIMEOUT_S=900
MAX_TURNS=2000
MAX_TOKENS_PER_TURN=8192

DB_PATH=./data/broker.db
TRAJECTORY_DIR=./trajectories
LOG_LEVEL=INFO
